    "compression": "1.7.4",
    "connect-timeout": "^1.9.0",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.21.1",
    "express-validator": "7.2.0",
    "helmet": "8.0.0",
    "i18next": "23.16.0",
    "mongoose": "8.7.1",
    "p-limit": "^6.1.0",
    "winston": "3.15.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "eslint": "^9.12.0",
    "husky": "^9.1.6",
    "jest": "29.7.0",
    "lint-staged": "^15.2.10",
    "nodemon": "3.1.7",
    "rimraf": "6.0.1",
    "supertest": "7.0.0"
