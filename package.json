{
  "name": "cosmic-echo",
  "version": "1.4.2",
  "description": "Cosmic Echo - An intelligent chatbot for customer service in high-dimensional space wellness studios, supporting multilingual communication and emotion analysis.",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "setup": "node setup.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write . && npm run lint:fix",
    "start": "node app.js",
    "dev:start": "cross-env NODE_ENV=development DEBUG=cosmic-echo:* nodemon --watch . app.js",
    "dev": "npm run dev:start",
    "test": "jest --ci --coverage",
    "test:watch": "jest --watch",
    "check": "npm run lint && npm run format && npm run check:security && npm run check:dependencies",
    "check:security": "npm audit",
    "check:dependencies": "ncu -u",
    "clean:logs": "rimraf logs/*",
    "start:prod": "cross-env NODE_ENV=production node app.js",
    "prepare": "husky install",
    "ci": "npm run test && npm run lint && npm run format && npm run check:security"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run check"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ]
  },
  "dependencies": {
    "@sentry/node": "^8.35.0",
    "axios": "^1.7.7",
    "axios-retry": "^4.5.0",
    "bcryptjs": "^2.4.3",
    "compromise": "^14.14.2",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "joi": "^17.13.3",
    "mongoose": "^8.7.2",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "sentiment": "^5.0.2",
    "vader-sentiment": "^1.1.3",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.25.9",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-security": "^3.0.1",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "npm-check-updates": "^17.1.5"
  },
  "engines": {
    "node": ">=18 <25",
    "npm": ">=10 <11"
  },
  "contributors": [
    {
      "name": "kafuo0425",
      "email": "kafuo0425@gmail.com"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kafuo0425/cosmic-echo.git"
  },
  "bugs": {
    "url": "https://github.com/kafuo0425/cosmic-echo/issues"
  },
  "homepage": "https://github.com/kafuo0425/cosmic-echo#readme",
  "keywords": [
    "chatbot",
    "customer-service",
    "multilingual",
    "emotion-analysis",
    "appointment-management",
    "Node.js",
    "Express",
    "MongoDB",
    "wellness",
    "AI",
    "SaaS"
  ],
  "license": "MIT",
  "private": true
}
