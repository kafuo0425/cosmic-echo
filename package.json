{
  "name": "cosmic-echo",
  "version": "1.1.0",
  "description": "A calm and intuitive chatbot that supports the spiritual and emotional guidance work of High-Dimensional Space.",
  "type": "commonjs",
  "main": "app.js",
  "scripts": {
    "postinstall": "husky install",
    "lint": "eslint --config eslint.config.cjs .",
    "lint:fix": "eslint --config eslint.config.cjs . --fix",
    "start": "cross-env NODE_ENV=production PORT=9587 node app.js",
    "start:dev": "cross-env NODE_ENV=development PORT=9587 nodemon app.js",
    "test": "jest --coverage --passWithNoTests",
    "check:security": "npm audit",
    "precommit": "npm run lint",
    "prepush": "npm test"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "compression": "^1.7.4",
    "connect-timeout": "^1.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "csrf": "^3.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "i18next": "^23.16.0",
    "mongoose": "^8.7.1",
    "p-limit": "^6.1.0",
    "vader-sentiment": "^1.1.3",
    "winston": "^3.15.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "eslint": "^9.12.0",
    "eslint-plugin-react": "^7.37.1",
    "glob": "^11.0.0",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "node-notifier": "^10.0.1",
    "nodemon": "^3.1.7",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18 <25"
  },
  "license": "MIT",
  "private": true,
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "git add"
    ]
  }
}
